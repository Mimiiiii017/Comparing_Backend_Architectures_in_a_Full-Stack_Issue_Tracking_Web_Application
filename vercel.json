{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/login",  "destination": "/api/auth.js" },
    { "source": "/api/me",     "destination": "/api/auth.js" },
    { "source": "/api/logout", "destination": "/api/auth.js" },
    { "source": "/dashboard",  "destination": "/dashboard.html" }
  ]
}