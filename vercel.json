{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/public/favicon.png" },
    { "source": "/api/(.*)", "destination": "/api/auth" }
  ],
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}